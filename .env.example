# =============================================================================
# WHOOP Stats — Environment Configuration
# =============================================================================
# Quick start:    ./setup.sh          (interactive wizard, recommended)
# Manual setup:   cp .env.example .env  then fill in values below
#
# Required variables are marked with [REQUIRED].
# Variables marked [AUTO] are generated automatically by setup.sh.
# See README.md for full setup instructions.
# =============================================================================

# --- Database ---
POSTGRES_USER=whoop_user
POSTGRES_PASSWORD=changeme              # [REQUIRED] [AUTO] Database password

# --- Security ---
# [REQUIRED] [AUTO] AES-256 encryption key for OAuth tokens at rest (exactly 32 chars).
# Auto-generated by setup.sh, or generate manually: openssl rand -hex 16
ENCRYPTION_KEY=

# --- WHOOP API ---
# [REQUIRED] Register at https://developer.whoop.com to get these.
# Add http://localhost:8081/callback as a Redirect URI in your WHOOP app.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_WEBHOOK_SECRET=                   # Only needed for webhook mode

# --- User ---
# [REQUIRED] [AUTO] Your WHOOP user ID.
# Auto-detected by setup.sh after OAuth, or find it in the WHOOP Developer Dashboard.
WHOOP_USER_ID=

# --- Logging & Performance ---
LOG_LEVEL=info                          # debug, info, warn, error

# --- Polling Intervals ---
# How often to fetch each data type from the WHOOP API (Go duration format).
POLL_INTERVAL_CYCLE=4h
POLL_INTERVAL_WORKOUT=30m
POLL_INTERVAL_SLEEP=1h
POLL_INTERVAL_SLEEP_OFFPEAK=4h          # Sleep polling outside 6 AM–12 PM
POLL_INTERVAL_PROFILE=24h

# --- Ports ---
BACKEND_PORT=8085                       # Host port for backend API
FRONTEND_PORT=3032                      # Host port for frontend dashboard

# --- CORS ---
# Comma-separated list of allowed CORS origins for the backend.
CORS_ALLOWED_ORIGINS=http://localhost:3032
